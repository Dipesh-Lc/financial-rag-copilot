LLM_PROVIDER=gemini
LLM_MODEL_NAME=gemini-3.1-pro-preview

# Set only the key for the provider you use
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
GOOGLE_API_KEY=

EDGAR_USER_AGENT=Your Name your_email@example.com

# Optional
# LLM_TEMPERATURE=0.0
# LLM_MAX_TOKENS=2048
# EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_DEVICE=cpu
# DEFAULT_TOP_K=5
# CHUNK_SIZE=800
# CHUNK_OVERLAP=150
# ENABLE_RETRIEVAL_UPGRADES=true
# ENABLE_MULTI_QUERY=true
# ENABLE_PARENT_DOCUMENT_RETRIEVAL=true
# MEMO_VALIDATION_RETRIES=2
# CHROMA_COLLECTION_NAME=sec_filings
# LOG_LEVEL=INFO
